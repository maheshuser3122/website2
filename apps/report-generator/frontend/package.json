{
  "name": "report-generator",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-grade React application for generating reports from Excel/SharePoint and exporting to PowerPoint",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
