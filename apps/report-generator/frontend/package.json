    "xlsx": "^0.18.5",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-react-app": "^7.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "react-router-dom": "^6.20.0",
