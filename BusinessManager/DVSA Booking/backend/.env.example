# ==============================================================================
# BOOKING SYSTEM BACKEND - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control
# ==============================================================================

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development
# For production, set to: production

# ============ FRONTEND URLS (CORS Configuration) ============
FRONTEND_URL=http://localhost:3000
# Additional origins (comma-separated):
# FRONTEND_URL=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# ============ JWT AUTHENTICATION ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Generate with: openssl rand -base64 32

# ============ STRIPE PAYMENT KEYS ============
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============ EMAIL CONFIGURATION (Nodemailer) ============
# Using Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@bookingsystem.com
SMTP_FROM_NAME=Booking System

# For other providers, update SMTP_HOST and SMTP_PORT:
# SendGrid: smtp.sendgrid.net:587
# Amazon SES: email-smtp.region.amazonaws.com:587
# Outlook: smtp.office365.com:587

# ============ DATABASE ============
# SQLite is recommended for simplicity
DATABASE_PATH=./system.db
# For PostgreSQL (future):
# DATABASE_URL=postgresql://user:password@localhost:5432/booking_system

# ============ LOGGING ============
LOG_LEVEL=info
# Options: error, warn, info, debug

# ============ MOCK DATA (Development Only) ============
ENABLE_SEED_DATA=false
# Set to true to auto-populate test data on startup

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============ SESSION TIMEOUT ============
SESSION_TIMEOUT_MINUTES=60
JWT_EXPIRY_HOURS=24

# ============ PAYMENT SETTINGS ============
# Booking fee in GBP
BOOKING_FEE=62.50
CURRENCY=gbp

# ============ FEATURE FLAGS ============
ENABLE_AUTO_BOOKING=true
ENABLE_EMAIL_CONFIRMATIONS=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_ADMIN_DASHBOARD=true

# ============ ADVANCED SETTINGS ============
# Max days in advance to book
MAX_BOOKING_DAYS=180

# Minimum hours before appointment to cancel
MIN_CANCEL_HOURS=72

# Reschedule only allowed within this period (days)
RESCHEDULE_WINDOW_DAYS=180

# Slot occupancy threshold warning (%)
OCCUPANCY_WARNING_THRESHOLD=80

# ============ API RATE LIMITS ============
API_TIMEOUT_MS=30000
MAX_PAYLOAD_SIZE=10mb

# ============ ADMIN SETTINGS ============
# Admin user ID (assign via database)
ADMIN_USER_ID=1

# ============ THIRD-PARTY INTEGRATIONS (Optional) ============
# Google Maps API (for distance calculation)
GOOGLE_MAPS_API_KEY=

# Twilio (for SMS notifications - future feature)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (alternative to SMTP)
SENDGRID_API_KEY=

# ============ MONITORING & ANALYTICS ============
# Sentry error tracking
SENTRY_DSN=

# Google Analytics
GOOGLE_ANALYTICS_ID=

# ============ SECURITY HEADERS ============
HELMET_ENABLED=true
CORS_ENABLED=true

# ============ DEVELOPMENT ONLY ============
DEBUG=false
MOCK_STRIPE=false
# When MOCK_STRIPE=true, payments are simulated without hitting Stripe API

# ============ TEMPLATE ENVIRONMENT VALUES ============
# Stripe Test Keys (for development)
# Secret: sk_test_4eC39HqLyjWDarhtT657j8F
# Public: pk_test_4eC39HqLyjWDarhjt657j8F

# Webhook Signing Secret:
# whsec_test_123456789

# JWT Secret (example):
# eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9

# ============ NOTES ============
# 1. Change JWT_SECRET to a strong random value in production
# 2. Use Stripe Live keys only in production
# 3. Enable HTTPS/TLS in production
# 4. Store this file securely (add to .gitignore)
# 5. Rotate secrets every 90 days
# 6. Never log sensitive values
